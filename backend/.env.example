# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://xiache:xiache@localhost:5432/xiache

# ── Storage ─────────────────────────────────────────────────────────────────
# Absolute or relative path where artifact ZIPs are stored
STORAGE_PATH=./data/artifacts

# ── Embedding (OpenAI-compatible API) ────────────────────────────────────────
# Leave EMBEDDING_API_KEY blank to disable embedding generation entirely.
EMBEDDING_API_KEY=
# Override to use a local/OpenAI-compatible endpoint (e.g. Ollama, vLLM)
EMBEDDING_API_BASE=
# Model name; must match 1536-dim output (or adjust EMBEDDING_DIMENSIONS)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Security ─────────────────────────────────────────────────────────────────
# Used for future JWT / signed token features. Must be kept secret in prod.
SECRET_KEY=change-me-in-production-please-use-a-strong-random-key

# ── Dev mode ─────────────────────────────────────────────────────────────────
# When true, the literal DEV_API_KEY is accepted without a DB lookup.
# NEVER enable in production.
XIACHE_DEV_MODE=true
DEV_API_KEY=dev-key-for-testing

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all (dev default)
CORS_ORIGINS=["*"]
