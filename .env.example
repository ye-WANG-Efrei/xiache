# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=xiache
POSTGRES_PORT=5432

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-please-use-a-strong-random-key

# ── Dev mode ─────────────────────────────────────────────────────────────────
# When true, "dev-key-for-testing" is accepted without a DB lookup.
XIACHE_DEV_MODE=true
DEV_API_KEY=dev-key-for-testing

# ── Embedding ────────────────────────────────────────────────────────────────
# Leave blank to run without embeddings (BM25-only search).
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=2048

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# URL the browser uses to reach the backend API
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_KEY=dev-key-for-testing
